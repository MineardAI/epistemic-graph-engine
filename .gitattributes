# Default: normalize all text files to LF in the repository
* text=auto eol=lf

# Python
*.py text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Configuration
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
